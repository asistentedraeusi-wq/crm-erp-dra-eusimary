# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ── Entorno ───────────────────────────────────────────────────
VITE_APP_ENV=development
# Valores: development | staging | production

# ── Cal.com (Citas) ───────────────────────────────────────────
VITE_CALCOM_API_KEY=

# ── Brevo / SMTP (Emails) ─────────────────────────────────────
VITE_BREVO_API_KEY=

# ── WhatsApp Business API ─────────────────────────────────────
VITE_WHATSAPP_TOKEN=
VITE_WHATSAPP_PHONE_ID=
